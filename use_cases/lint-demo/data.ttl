@prefix ld:   <http://example.org/ld#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# Tiny sample so Hydration Pipeline produces SOME nodes after the
# linter rules have been exercised in the Refine sub-tab. Just enough
# to verify the data path still works end-to-end on the unbroken
# parts of the schema.

ld:Customer_C001
    a ld:Customer ;
    rdfs:label "Customer C001" ;
    ld:customerName "Acme Corp" .

ld:Customer_C002
    a ld:Customer ;
    rdfs:label "Customer C002" ;
    ld:customerName "Beta LLC" .

ld:Order_O100
    a ld:Order ;
    rdfs:label "Order O100" ;
    ld:orderId 100 ;
    ld:customerId 1 ;
    ld:placedBy ld:Customer_C001 .

ld:Order_O101
    a ld:Order ;
    rdfs:label "Order O101" ;
    ld:orderId 101 ;
    ld:customerId 2 ;
    ld:placedBy ld:Customer_C002 .

ld:IsolatedLeaf_L001
    a ld:IsolatedLeaf ;
    rdfs:label "Isolated Leaf 1" ;
    ld:leafName "Standalone entity — won't connect to anything in the graph view." .

# Bare instances of the deliberately-empty classes. Without these, stage 6's
# auto-generated `count(<Class>) >= 1` check fails because the manifest declares
# them in in_scope_classes but they have no properties to populate. The classes
# themselves are intentionally broken to exercise the linter; these one-line
# instances exist purely to keep the hydration pipeline green so operators can
# walk the whole loop end-to-end.
ld:Orphan_X1
    a ld:Orphan ;
    rdfs:label "Orphan instance — no properties (class has none defined)" .

ld:bad_class_X1
    a ld:bad_class ;
    rdfs:label "bad_class instance — exists only so stage 6 validation passes" .
