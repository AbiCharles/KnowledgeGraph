# ── Neo4j AuraDB ──────────────────────────────────────────────────────────────
# Get these from your AuraDB instance dashboard at https://aura.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-aura-password

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# ── Pipeline ──────────────────────────────────────────────────────────────────
# Paths to TTL files (relative to repo root)
ONTOLOGY_TTL_PATH=ontology/kf-mfg-workorder.ttl
DATA_TTL_PATH=data/kf-mfg-workorder-test.ttl

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
